uploads/profiles/*
uploads/receipts/*
uploads/settings/*
admin/uploads/**
!admin/uploads/.gitkeep
!admin/uploads/videos/
!admin/uploads/videos/.gitkeep
!uploads/profiles/.gitkeep
!uploads/receipts/.gitkeep
!uploads/settings/.gitkeep

# ============================================
